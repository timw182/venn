# Venn Backend — Environment Variables
# Copy to .env and fill in real values before running.

# Session signing key (REQUIRED in production, auto-generated in DEBUG mode)
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Frontend origin for CORS (default: https://venn.lu)
FRONTEND_ORIGIN=https://venn.lu

# Additional CORS origins, comma-separated (optional)
EXTRA_ORIGINS=http://localhost:5173,http://localhost:81

# Enable debug mode — exposes /api/docs, /api/redoc, allows ephemeral SECRET_KEY
# Set to "true" for local development (default: false)
DEBUG=false

# SQLite database file path (default: kinklink.db)
DB_PATH=kinklink.db

# Cookie domain for session cookie (default: venn.lu)
# Use localhost for local development
COOKIE_DOMAIN=venn.lu

# Logging level — DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO
