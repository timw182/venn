{
  "expo": {
    "name": "Venn",
    "slug": "venn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.amoreapp.venn",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "net.amoreapp.venn",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon_venn.png"
    },
    "extra": {
      "apiBase": "https://api.venn.lu/api",
      "wsBase": "wss://api.venn.lu/api/ws",
      "eas": {
        "projectId": "8007ff9e-e39a-496f-80fd-59704ca6cba0"
      }
    },
    "plugins": [
      "expo-font",
      "expo-updates",
      "expo-secure-store"
    ]
  }
}
